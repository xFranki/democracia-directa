NODE_ENV=development
PORT=3001

# PostgreSQL
DATABASE_URL="postgresql://usuario:contraseña@localhost:5432/democracia_directa"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT — genera con: openssl rand -base64 64
JWT_ACCESS_SECRET="cambia-esto-por-un-secreto-de-64-chars-minimo-AAAAAAAAAAAAAAAAAAAA"
JWT_REFRESH_SECRET="cambia-esto-por-otro-secreto-diferente-BBBBBBBBBBBBBBBBBBBBBBBB"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# Frontend URL
FRONTEND_URL="http://localhost:3000"

# SMTP — puedes usar Gmail, Resend o Mailtrap para desarrollo
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="tu-email@gmail.com"
SMTP_PASS="tu-app-password"
EMAIL_FROM="noreply@democraciadirecta.es"

# Seguridad
BCRYPT_ROUNDS=12
